# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# Discord Application Client ID (from Discord Developer Portal)
CLIENT_ID=your_client_id_here

# (Optional) Guild ID for testing — commands deploy instantly to this guild
# Remove or leave empty for global command deployment
GUILD_ID=your_guild_id_here

# ============================================================
# Settings Dashboard (optional)
# ============================================================

# Set to "true" to enable the web settings dashboard
SETTINGS_ENABLED=false

# Discord OAuth2 Client Secret (from Discord Developer Portal > OAuth2)
CLIENT_SECRET=your_client_secret_here

# The Discord Role ID that grants access to the settings dashboard
# (Right-click the role in Server Settings > Roles with Developer Mode on, then Copy Role ID)
SETTINGS_ADMIN_ROLE_ID=your_admin_role_id_here

# Port for the settings dashboard web server (default: 3000)
SETTINGS_PORT=3000

# OAuth2 redirect URI — must match what you set in Discord Developer Portal
# For local development: http://localhost:3000/auth/callback
# For production: https://yourdomain.com/auth/callback
SETTINGS_REDIRECT_URI=http://localhost:3000/auth/callback

# Session secret for the settings dashboard (change this to a random string!)
SESSION_SECRET=change-me-to-a-random-string
