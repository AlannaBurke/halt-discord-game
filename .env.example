# ============================================================
# HALT Bot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# See README.md for a step-by-step setup guide.
# ============================================================

# ============================================================
# Core Bot Settings (Required)
# ============================================================

# DISCORD_TOKEN
# Where to get it: Discord Developer Portal > Your Application > Bot > Reset Token
# This is the secret token that lets the bot log in. Keep it private!
DISCORD_TOKEN=your_bot_token_here

# CLIENT_ID
# Where to get it: Discord Developer Portal > Your Application > OAuth2 > Client ID
# This is the public application ID used for registering slash commands and OAuth2.
CLIENT_ID=your_client_id_here

# GUILD_ID (Optional but recommended)
# Where to get it: In Discord, enable Developer Mode (User Settings > Advanced),
#   then right-click your server name in the sidebar > Copy Server ID
# When set, slash commands register instantly to this server.
# When empty, commands deploy globally (can take up to 1 hour to appear).
GUILD_ID=your_guild_id_here

# ============================================================
# Settings Dashboard (Optional)
# ============================================================
# The dashboard lets admins manage cards, fundraiser settings,
# and view setup instructions from a web browser.

# SETTINGS_ENABLED
# Set to "true" to start the web dashboard alongside the bot.
SETTINGS_ENABLED=false

# CLIENT_SECRET
# Where to get it: Discord Developer Portal > Your Application > OAuth2 > Reset Secret
# Required for Discord OAuth2 login on the dashboard.
CLIENT_SECRET=your_client_secret_here

# SETTINGS_ADMIN_ROLE_ID
# Where to get it: In Discord, go to Server Settings > Roles,
#   right-click the admin role > Copy Role ID (Developer Mode must be on)
# Only users with this role can log into the settings dashboard.
SETTINGS_ADMIN_ROLE_ID=your_admin_role_id_here

# SETTINGS_PORT
# The port the dashboard web server listens on. Default: 3000.
SETTINGS_PORT=3000

# SETTINGS_REDIRECT_URI
# Must exactly match the redirect URI you added in Discord Developer Portal > OAuth2 > Redirects.
# For local development: http://localhost:3000/auth/callback
# For production: https://yourdomain.com/auth/callback
SETTINGS_REDIRECT_URI=http://localhost:3000/auth/callback

# SESSION_SECRET
# Any random string used to encrypt web sessions. Change this to something unique!
# Example: generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-string

# ============================================================
# Fundraiser System (Optional)
# ============================================================
# Enables donation tracking, thermometer graphics, and
# admin verification of CashApp donations.

# FUNDRAISER_ENABLED
# Set to "true" to enable the /donate, /fundraiser, /donated, /confirm, /deny, and /pending commands.
FUNDRAISER_ENABLED=false

# FUNDRAISER_GOAL_AMOUNT
# The target fundraiser amount in dollars (numeric, no $ sign).
FUNDRAISER_GOAL_AMOUNT=500

# FUNDRAISER_GOAL_LABEL
# The name/title shown on the thermometer graphic and in embeds.
FUNDRAISER_GOAL_LABEL=HALT Fundraiser

# FUNDRAISER_PAYPAL_LINK
# Direct PayPal donation link. Users are sent here from the /donate command.
# Where to get it: Go to paypal.me and create your link, e.g. https://paypal.me/YourName
FUNDRAISER_PAYPAL_LINK=https://paypal.me/yourlink

# FUNDRAISER_CASHAPP_TAG
# Your CashApp cashtag (starts with $). Shown in the /donate embed.
# Where to get it: Open CashApp > Profile > Your $cashtag
FUNDRAISER_CASHAPP_TAG=$YourCashTag

# FUNDRAISER_ANNOUNCEMENT_CHANNEL_ID
# Where to get it: In Discord, right-click the channel where you want
#   donation announcements posted > Copy Channel ID (Developer Mode must be on)
FUNDRAISER_ANNOUNCEMENT_CHANNEL_ID=your_channel_id_here
